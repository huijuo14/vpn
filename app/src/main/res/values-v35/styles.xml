<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Psiphon" parent="Theme.AppCompat">
        <!-- workaround for opting out of edge-to-edge enforcement, v35+ specific -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
        <!-- AMOLED pitch black theme -->
        <item name="android:windowBackground">@color/amoled_background</item>
        <item name="android:colorBackground">@color/amoled_background</item>
        <item name="android:statusBarColor">@color/amoled_background</item>
        <item name="android:navigationBarColor">@color/amoled_background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorAccent">@color/accent_color</item>
        <item name="colorPrimary">@color/amoled_background</item>
        <item name="colorPrimaryDark">@color/amoled_background</item>
    </style>
    <style name="Theme.Psiphon.NoActionBar" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
        <item name="android:statusBarColor">@color/amoled_background</item>
        <item name="android:navigationBarColor">@color/amoled_background</item>
    </style>

</resources>